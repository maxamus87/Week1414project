DATABASE_URL="postgresql://username:password@localhost:5433/database-name?schema=public"
# Only needed when deploying behind a connection pooler (e.g. Neon/Vercel Postgres):
# a non-pooled connection string used when running Prisma migrations.
DIRECT_URL="postgresql://username:password@localhost:5433/database-name?schema=public"
PORT=3001
JWT_SECRET=change-this-to-a-long-random-string
